@model group_project.Models.HoroscopeInfo

<div style="text-align: center; padding: 40px;">
    <h1>@Model.SignName</h1>

    <img src="@Model.ImagePath" alt="@Model.SignName" style="width: 220px; margin: 20px 0;" />

    <p style="font-size: 20px; max-width: 700px; margin: 0 auto;">
        @Model.HoroscopeText
    </p>

    <a asp-controller="Home" asp-action="Horoscope" style="display: inline-block; margin-top: 25px;">
        Назад до гороскопів
    </a>
</div>