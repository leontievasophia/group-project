@model group_project.Models.HoroscopeInfo

@{
    Layout = null;
    ViewData["Title"] = Model.SignName;
}

<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="/css/styles.css" />
</head>

<body class="horoscope-details-page">
    <header class="details-header">
        <a asp-controller="Home" asp-action="Index" class="details-logo">
            MysticHub
        </a>

        <nav class="details-nav">
            <a asp-controller="Home" asp-action="Index">Головна</a>
            <a asp-controller="Home" asp-action="Horoscope">Гороскоп</a>
            <a href="#">Сумісність</a>
        </nav>
    </header>

    <main class="details-main">
        <section class="details-hero">
            <div class="details-top">
                <img src="@Model.ImagePath" alt="@Model.SignName" class="details-zodiac-image" />

                <h1 class="details-title">
                    @Model.SignName
                </h1>
            </div>

            <div class="details-text-card">
                <p>
                    @Model.HoroscopeText
                </p>
            </div>

            <a asp-controller="Home" asp-action="Horoscope" class="details-back-button">
                Назад до гороскопів
            </a>
        </section>
    </main>
</body>
</html>